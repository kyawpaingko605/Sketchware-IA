<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical"
    android:paddingHorizontal="4dp"
    android:paddingVertical="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_bot"
        android:orientation="vertical"
        android:padding="12dp">

      <TextView
        android:id="@+id/text_status_chip"
        android:layout_width="wrap_content"
        android:layout_height="26dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_chat_status_chip"
        android:gravity="center"
        android:paddingLeft="9dp"
        android:paddingRight="9dp"
        android:textColor="@color/chat_accent"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layout_reasoning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_tool_json_box"
            android:orientation="vertical"
            android:padding="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reasoning"
                android:textColor="@color/chat_accent"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_reasoning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.82"
                android:textColor="@color/chat_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/chat_text_primary"
            android:textSize="12sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/text_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="3dp"
        android:textColor="@color/chat_text_hint"
        android:textSize="12sp" />
</LinearLayout>
