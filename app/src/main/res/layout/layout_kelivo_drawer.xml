<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/chat_surface"
  android:fitsSystemWindows="true"
  android:orientation="vertical">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="15dp"
    android:orientation="vertical">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_weight="1"
        android:background="@drawable/bg_kelivo_search"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <ImageView
          android:layout_width="16dp"
          android:layout_height="16dp"
          android:contentDescription="@null"
          android:src="@drawable/kelivo_lucide_bot_message_square"
          android:tint="@color/chat_text_hint" />

        <EditText
          android:id="@+id/drawer_search"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_marginStart="10dp"
          android:background="@android:color/transparent"
          android:fontFamily="sans-serif"
          android:hint="@string/kelivo_drawer_search_hint"
          android:imeOptions="actionSearch"
          android:inputType="text"
          android:maxLines="1"
          android:textColor="@color/chat_text_primary"
          android:textColorHint="@color/chat_text_hint"
          android:textSize="14sp" />
      </LinearLayout>

      <ImageView
        android:id="@+id/btn_drawer_history"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/kelivo_drawer_history"
        android:padding="8dp"
        android:src="@drawable/kelivo_lucide_history"
        android:tint="@color/black" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/drawer_threads_list"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_marginTop="16dp"
      android:layout_weight="1"
      android:clipToPadding="false"
      android:overScrollMode="never"
      android:paddingTop="4dp"
      android:paddingBottom="8dp" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:paddingTop="8dp">

      <FrameLayout
        android:id="@+id/drawer_user_avatar_container"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_kelivo_avatar"
        android:foreground="?attr/selectableItemBackgroundBorderless">

        <ImageView
          android:id="@+id/drawer_user_avatar_image"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:contentDescription="@string/kelivo_profile_avatar"
          android:scaleType="centerCrop"
          android:visibility="gone" />

        <TextView
          android:id="@+id/drawer_user_avatar"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:fontFamily="sans-serif-medium"
          android:gravity="center"
          android:text="f"
          android:textColor="@color/kelivo_avatar_text"
          android:textSize="14sp" />
      </FrameLayout>

      <TextView
        android:id="@+id/drawer_user_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:text="@string/kelivo_default_user"
        android:textColor="@color/chat_text_primary"
        android:textSize="14sp" />

      <ImageView
        android:id="@+id/btn_drawer_settings"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/kelivo_drawer_settings"
        android:padding="8dp"
        android:src="@drawable/kelivo_lucide_settings"
        android:tint="@color/black" />
    </LinearLayout>
  </LinearLayout>

</LinearLayout>
