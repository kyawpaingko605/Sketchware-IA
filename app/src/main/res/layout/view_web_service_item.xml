<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/chat_surface"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/chat_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="82dp"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/web_service_icon"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_chat_project_icon"
            android:padding="11dp"
            android:scaleType="fitCenter"
            app:tint="@color/chat_accent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/web_service_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/chat_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Ebook Maker" />

            <TextView
                android:id="@+id/web_service_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/chat_text_secondary"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="https://ebookmeker.online/" />

        </LinearLayout>

        <ImageView
            android:id="@+id/web_service_arrow"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="9dp"
            android:src="@drawable/kelivo_lucide_chevron_right"
            app:tint="@color/chat_text_secondary" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

