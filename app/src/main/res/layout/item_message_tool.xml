<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_tool_card"
    android:elevation="3dp"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:id="@+id/layout_tool_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/img_tool_icon"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_icon_box"
            android:scaleType="center"
            android:padding="11dp"
            android:src="@drawable/ic_file" />

        <TextView
            android:id="@+id/text_tool_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Using decrypt_sketchware_file"
            android:textColor="@color/chat_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp">
            
            <ProgressBar
                android:id="@+id/progress_tool"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/img_tool_status"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_status_success"
                android:scaleType="center"
                android:padding="10dp"
                android:src="@drawable/ic_mtrl_check" />
        </FrameLayout>

        <!-- Hidden but kept for code compatibility -->
        <ImageView
            android:id="@+id/img_expand"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_tool_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_tool_args"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_json_box"
            android:fontFamily="monospace"
            android:padding="10dp"
            android:text="{&quot;file_path&quot;:&quot;./data/601/data.json&quot;}"
            android:textColor="@color/chat_text_primary"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Result:"
            android:textColor="@color/chat_accent"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_tool_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_success_box"
            android:padding="14dp"
            android:text="Success"
            android:textColor="@color/chat_text_primary"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/layout_approval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_reject_tool"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rejeitar"
                android:textColor="#F44336" />

            <Button
                android:id="@+id/btn_approve_tool"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/chat_accent"
                android:text="Aprovar"
                android:textColor="@android:color/white" />
        </LinearLayout>
            
    </LinearLayout>

</LinearLayout>
