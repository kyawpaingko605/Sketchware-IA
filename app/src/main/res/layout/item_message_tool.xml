<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingTop="8dp"
    android:paddingEnd="16dp"
    android:paddingBottom="4dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_tool"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="64dp"
        app:cardBackgroundColor="?colorSurfaceVariant"
        app:cardCornerRadius="12dp"
        app:cardUseCompatPadding="true"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="?colorOutlineVariant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Tool Header (Clickable for expanding) -->
            <LinearLayout
                android:id="@+id/layout_tool_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/img_tool_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_mtrl_code"
                    app:tint="?colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/text_tool_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="Reading file Utils.java" />

                <ProgressBar
                    android:id="@+id/progress_tool"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="12dp"
                    android:indeterminateTint="?colorOnSurfaceVariant" />

                <ImageView
                    android:id="@+id/img_tool_status"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_mtrl_done"
                    app:tint="?colorTertiary"
                    android:visibility="gone" />
                    
                <ImageView
                    android:id="@+id/img_expand"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_arrow_drop_down_24px"
                    app:tint="?colorOnSurfaceVariant" />
            </LinearLayout>

            <!-- Tool Details (Expanded content) -->
            <LinearLayout
                android:id="@+id/layout_tool_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone"
                tools:visibility="visible">
                
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="8dp"
                    android:background="?colorOutlineVariant" />

                <TextView
                    android:id="@+id/text_tool_args"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textSize="11sp"
                    android:textIsSelectable="true"
                    tools:text='{"path": "Utils.java"}' />
                    
                <TextView
                    android:id="@+id/text_tool_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="monospace"
                    android:textColor="?colorOnSurface"
                    android:textSize="11sp"
                    android:textIsSelectable="true"
                    tools:text="Result: File contents..." />

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
