<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/studio_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/studio_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/studio_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/studio_surface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/studio_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/studio_surface"
            app:navigationIcon="@drawable/ic_mtrl_arrow_left"
            app:subtitleTextColor="@color/studio_text_secondary"
            app:titleTextColor="@color/studio_text_primary"
            tools:subtitle=".sketcware_ide/601"
            tools:title="Android Studio Project" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/studio_progress"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorColor="@color/studio_accent"
            app:trackColor="@color/studio_border"
            tools:visibility="visible" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/studio_tabs"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@color/studio_surface"
            app:tabGravity="start"
            app:tabIndicatorColor="@color/studio_accent"
            app:tabIndicatorFullWidth="false"
            app:tabMode="scrollable"
            app:tabSelectedTextColor="@color/studio_accent"
            app:tabTextColor="@color/studio_text_secondary" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:id="@+id/studio_body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/studio_file_panel"
            android:layout_width="156dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_studio_panel"
            android:orientation="vertical">

            <TextView
                android:id="@+id/studio_file_panel_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:text="@string/studio_files"
                android:textColor="@color/studio_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/studio_project_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:singleLine="true"
                android:textColor="@color/studio_text_secondary"
                android:textSize="11sp"
                tools:text=".sketcware_ide/601" />

            <HorizontalScrollView
                android:id="@+id/studio_file_tree_horizontal_scroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:scrollbars="horizontal">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/studio_file_tree"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:minWidth="156dp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingBottom="8dp"
                    tools:itemCount="10"
                    tools:listitem="@layout/item_studio_file_tree" />
            </HorizontalScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/studio_workspace_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/studio_file_header"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_studio_surface_alt"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:id="@+id/studio_selected_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_mtrl_file"
                    android:tint="@color/studio_text_secondary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/studio_selected_file"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:text="@string/studio_select_file"
                        android:textColor="@color/studio_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/studio_selected_path"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:textColor="@color/studio_text_secondary"
                        android:textSize="11sp"
                        tools:text="app/src/main/java/MainActivity.java" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/studio_stage"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/studio_code_background">

                <io.github.rosemoe.sora.widget.CodeEditor
                    android:id="@+id/studio_editor"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <ScrollView
                    android:id="@+id/studio_xml_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/studio_surface"
                    android:fillViewport="true"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/studio_xml_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.12"
                        android:padding="16dp"
                        android:textColor="@color/studio_text_primary"
                        android:textIsSelectable="true"
                        android:textSize="13sp"
                        tools:text="&lt;LinearLayout /&gt;" />
                </ScrollView>

                <ScrollView
                    android:id="@+id/studio_output_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/studio_output_background"
                    android:fillViewport="true"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/studio_output"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:padding="16dp"
                        android:text="@string/studio_output_ready"
                        android:textColor="@color/studio_text_primary"
                        android:textIsSelectable="true"
                        android:textSize="12sp" />
                </ScrollView>

                <LinearLayout
                    android:id="@+id/studio_empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_mtrl_folder_code"
                        android:tint="@color/studio_text_secondary" />

                    <TextView
                        android:id="@+id/studio_empty_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="@string/studio_no_file_title"
                        android:textColor="@color/studio_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/studio_empty_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="@string/studio_no_file_message"
                        android:textColor="@color/studio_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/studio_status"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:background="@color/studio_status_background"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:textColor="@color/studio_text_secondary"
                android:textSize="11sp"
                tools:text="Ready" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
