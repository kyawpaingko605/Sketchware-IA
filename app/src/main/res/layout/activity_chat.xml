<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/chat_background"
    android:fitsSystemWindows="true"
    tools:context=".ChatActivity">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/headerChat"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_header_button"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/chat_text_primary"
            android:textSize="36sp" />

        <TextView
            android:id="@+id/txtChatTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:text="Chat - LEO_AI"
            android:textColor="@color/chat_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />
            
        <TextView
            android:id="@+id/text_typing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="..."
            android:textColor="@color/chat_accent"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnMenu"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_header_button"
            android:gravity="center"
            android:text="⋮"
            android:textColor="@color/chat_text_primary"
            android:textSize="26sp" />

    </LinearLayout>

    <!-- LISTA DE MENSAGENS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_messages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/inputContainer"
        android:layout_below="@id/headerChat"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp" />

    <!-- INPUT FIXO EMBAIXO -->
    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="140dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="14dp"
        android:background="@drawable/bg_chat_input"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/text_files_changed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_file"
            android:drawablePadding="8dp"
            android:text="0 Files With Changes"
            android:textColor="@color/chat_text_secondary"
            android:textSize="13sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="@color/chat_divider" />

        <EditText
            android:id="@+id/edit_text_message"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="What do you want me to build?"
            android:inputType="textMultiLine"
            android:maxLines="3"
            android:textColor="@color/chat_text_primary"
            android:textColorHint="@color/chat_text_hint"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_attach"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_round_outline"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/chat_text_primary"
                android:textSize="30sp" />

            <LinearLayout
                android:id="@+id/btn_model_selector"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_model_chip"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:orientation="horizontal">
                
                <TextView
                    android:id="@+id/text_current_model"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Llama 3.1 8B"
                    android:textColor="@color/chat_text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/btn_mic"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="🎙"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/btn_send"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_send_button"
                android:gravity="center"
                android:text="➤"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
