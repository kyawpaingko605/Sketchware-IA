<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/chat_background"
    android:fitsSystemWindows="true"
    tools:context=".ChatActivity">

    <RelativeLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/chat_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:background="@color/chat_surface"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingTop="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/btn_drawer_menu"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/kelivo_open_drawer"
                android:padding="10dp"
                android:src="@drawable/ic_kelivo_menu" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/text_chat_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/chat_thread_new_title"
                    android:textColor="@color/chat_text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/text_chat_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/chat_text_secondary"
                    android:textSize="12sp"
                    tools:text="Qwen/Qwen3-8B (SiliconFlow)" />
            </LinearLayout>

            <ImageView
                android:id="@+id/btn_header_map"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/kelivo_header_map"
                android:padding="8dp"
                android:src="@drawable/ic_mtrl_map"
                android:tint="@color/chat_text_primary" />

            <ImageView
                android:id="@+id/btn_header_new_chat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/kelivo_header_new_chat"
                android:padding="8dp"
                android:src="@drawable/ic_mtrl_add"
                android:tint="@color/chat_text_primary" />
        </LinearLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/chat_page_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/chat_header"
            android:background="@color/chat_surface"
            android:visibility="gone"
            app:tabGravity="fill"
            app:tabIndicatorColor="@color/chat_accent"
            app:tabMode="fixed"
            app:tabSelectedTextColor="@color/chat_accent"
            app:tabTextColor="@color/chat_text_secondary" />

        <androidx.viewpager.widget.ViewPager
            android:id="@+id/chat_view_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/inputContainer"
            android:layout_below="@id/chat_header" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/inputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/chat_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kelivo_border_soft"
            app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/text_files_changed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_chat_thread_badge"
                android:drawableStart="@drawable/ic_file"
                android:drawablePadding="8dp"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:maxLines="1"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="@string/chat_changed_files_placeholder"
                android:textColor="@color/chat_text_secondary"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_selected_context"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_chat_thread_badge"
                android:ellipsize="end"
                android:maxLines="2"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:textColor="@color/chat_text_secondary"
                android:textSize="12sp"
                android:visibility="gone" />

            <HorizontalScrollView
                android:id="@+id/selected_image_preview_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:overScrollMode="never"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/selected_image_preview_list"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <EditText
                android:id="@+id/edit_text_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="top|start"
                android:hint="@string/kelivo_input_hint"
                android:importantForAutofill="no"
                android:inputType="textCapSentences|textMultiLine"
                android:lineSpacingExtra="2dp"
                android:maxLines="6"
                android:minHeight="44dp"
                android:paddingTop="0dp"
                android:paddingBottom="4dp"
                android:textColor="@color/chat_text_primary"
                android:textColorHint="@color/chat_text_hint"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:minHeight="40dp"
                android:orientation="horizontal"
                android:paddingBottom="2dp">

                <ImageView
                    android:id="@+id/btn_model_selector"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/chat_model_selector_content_description"
                    android:padding="6dp"
                    android:src="@drawable/ic_kelivo_brand" />

                <ImageView
                    android:id="@+id/btn_input_web"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/kelivo_input_web"
                    android:padding="7dp"
                    android:src="@drawable/ic_kelivo_globe" />

                <ImageView
                    android:id="@+id/btn_chat_mode"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/chat_mode_agent"
                    android:padding="7dp"
                    android:src="@drawable/ic_kelivo_reasoning" />

                <ImageView
                    android:id="@+id/btn_input_tools"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/kelivo_input_tools"
                    android:padding="7dp"
                    android:src="@drawable/ic_kelivo_hammer" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/text_chat_mode"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/text_current_model"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/btn_attach"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/chat_attach_content_description"
                    android:padding="6dp"
                    android:src="@drawable/ic_kelivo_plus" />

                <ImageView
                    android:id="@+id/btn_microphone"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/btn_cancel_run"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Cancel current run"
                    android:padding="7dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="@color/chat_text_secondary"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/btn_send"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_kelivo_send"
                    android:contentDescription="@string/chat_send_content_description"
                    android:padding="9dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_kelivo_send_arrow" />
            </LinearLayout>
        </LinearLayout>

        </com.google.android.material.card.MaterialCardView>
    </RelativeLayout>

    <include
        android:id="@+id/drawer_content"
        layout="@layout/layout_kelivo_drawer"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
