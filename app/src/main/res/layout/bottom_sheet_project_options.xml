<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_kelivo_bottom_sheet"
    android:orientation="vertical">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/project_options_title"
            android:textColor="@color/chat_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_project_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/chat_text_secondary"
            android:textSize="13sp"
            tools:text="690" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fadeScrollbars="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:id="@+id/pin_project"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_option_row"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:id="@+id/pin_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    app:srcCompat="@drawable/ic_mtrl_pin"
                    app:tint="@color/chat_accent" />

                <TextView
                    android:id="@+id/pin_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@string/project_options_pin"
                    android:textColor="@color/chat_text_primary"
                    android:textSize="15sp"
                    app:drawableEndCompat="@drawable/ic_mtrl_arrow_right"
                    app:drawableTint="@color/chat_text_hint" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/project_backup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_chat_option_row"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    app:srcCompat="@drawable/ic_mtrl_history"
                    app:tint="@color/chat_accent" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@string/project_options_backup"
                    android:textColor="@color/chat_text_primary"
                    android:textSize="15sp"
                    app:drawableEndCompat="@drawable/ic_mtrl_arrow_right"
                    app:drawableTint="@color/chat_text_hint" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/export_sign"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chat_option_row"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    app:srcCompat="@drawable/ic_mtrl_export"
                    app:tint="@color/chat_accent" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@string/project_options_export_sign"
                    android:textColor="@color/chat_text_primary"
                    android:textSize="15sp"
                    app:drawableEndCompat="@drawable/ic_mtrl_arrow_right"
                    app:drawableTint="@color/chat_text_hint" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/project_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_chat_option_row"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    app:srcCompat="@drawable/ic_mtrl_tune"
                    app:tint="@color/chat_accent" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@string/project_options_change_settings"
                    android:textColor="@color/chat_text_primary"
                    android:textSize="15sp"
                    app:drawableEndCompat="@drawable/ic_mtrl_arrow_right"
                    app:drawableTint="@color/chat_text_hint" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/project_config"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chat_option_row"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    app:srcCompat="@drawable/ic_mtrl_toggle"
                    app:tint="@color/chat_accent" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@string/project_options_configuration"
                    android:textColor="@color/chat_text_primary"
                    android:textSize="15sp"
                    app:drawableEndCompat="@drawable/ic_mtrl_arrow_right"
                    app:drawableTint="@color/chat_text_hint" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/project_delete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_chat_option_row_error"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    app:srcCompat="@drawable/ic_mtrl_delete"
                    app:tint="@color/chat_error" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@string/project_options_delete"
                    android:textColor="@color/chat_error"
                    android:textSize="15sp"
                    app:drawableEndCompat="@drawable/ic_mtrl_arrow_right"
                    app:drawableTint="@color/chat_error" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
