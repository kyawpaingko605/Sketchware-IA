<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/layout_editor_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:subtitleTextColor="@android:color/white"
        app:titleTextColor="@android:color/white"
        tools:subtitle="activity_main.xml"
        tools:title="@string/studio_layout_editor_title" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/layout_editor_palette_panel"
            android:layout_width="116dp"
            android:layout_height="match_parent"
            android:background="?attr/colorBackgroundFloating"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/studio_layout_editor_palette"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/layout_editor_palette_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="8dp" />
            </ScrollView>
        </LinearLayout>

        <ScrollView
            android:id="@+id/layout_editor_scroll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fillViewport="true">

            <FrameLayout
                android:id="@+id/layout_editor_canvas_holder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="560dp"
                android:padding="14dp">

                <LinearLayout
                    android:id="@+id/layout_editor_canvas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_studio_layout_canvas"
                    android:minHeight="520dp"
                    android:orientation="vertical"
                    android:padding="10dp" />

                <TextView
                    android:id="@+id/layout_editor_empty"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:padding="24dp"
                    android:text="@string/studio_layout_editor_empty"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="14sp" />
            </FrameLayout>
        </ScrollView>
    </LinearLayout>

    <TextView
        android:id="@+id/layout_editor_status"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:background="?attr/colorBackgroundFloating"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:singleLine="true"
        android:text="@string/studio_layout_editor_ready"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="11sp" />
</LinearLayout>
